DISCORD_TOKEN=coloque_o_token_do_bot_aqui
DISCORD_CLIENT_ID=coloque_o_client_id_do_app_aqui
DISCORD_GUILD_ID=coloque_o_guild_id_do_servidor_aqui
DISCORD_PUBLIC_KEY=coloque_a_public_key_do_app_aqui

# Use "firestore" em producao na Vercel. Para desenvolvimento local sem Firebase,
# deixe vazio para usar o fallback em JSON.
STORAGE_DRIVER=firestore

# JSON completo da service account do Firebase em uma unica linha.
# Exemplo: {"type":"service_account","project_id":"..."}
FIREBASE_SERVICE_ACCOUNT_JSON=


# Apenas para desenvolvimento local sem assinatura do Discord.
SKIP_DISCORD_SIGNATURE=false
